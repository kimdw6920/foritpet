# 복사 후 .env 로 저장하고 값을 채우세요. .env 는 Git에 올리지 마세요.

# 필수(프로덕션): 임의의 긴 문자열로 변경
# DJANGO_SECRET_KEY=

# true / false (기본 개발: true)
# DJANGO_DEBUG=true

# 쉼표로 구분 (예: example.com,127.0.0.1)
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# HTTPS 사용 배포 시: 1 (기본: DEBUG 가 꺼지면 1)
# 로컬에서 DEBUG=false 인데 HTTP 로 테스트할 때만 0
# DJANGO_USE_HTTPS=1

# 세션 유지 시간(초). 기본 3600 = 1시간
# SESSION_COOKIE_AGE=3600

# HTTPS 사이트에서 CSRF 오류 시 도메인 추가 (쉼표 구분)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 포트원 결제 (서버 검증 사용 시 필수)
# PORTONE_IMP_CODE=imp88875057
# PORTONE_REST_API_KEY=
# PORTONE_REST_API_SECRET=
